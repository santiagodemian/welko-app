// ─── Welko — Prisma Schema ────────────────────────────────────────────────────
//
// Encrypted fields (AES-256-GCM via lib/encryption.ts):
//   Clinic.customizationPrompt, Clinic.crmApiKeys, Clinic.googleRefreshToken
//   Lead.patientName, Lead.patientPhone, Lead.callTranscript, Lead.notes
//
// After any schema change:
//   npx prisma migrate dev --name <description>
//   npx prisma generate
// ──────────────────────────────────────────────────────────────────────────────

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// ─── Enums ────────────────────────────────────────────────────────────────────

enum LeadStatus {
  NUEVO
  EN_SEGUIMIENTO_IA
  CITA_CONFIRMADA
  REVENUE_CERRADO
  PERDIDO
}

enum LeadChannel {
  WHATSAPP
  INSTAGRAM
  FACEBOOK
  LLAMADA
  WEB
}

// ─── Clinic ───────────────────────────────────────────────────────────────────

model Clinic {
  id          String @id @default(cuid())
  clerkUserId String @unique
  name        String
  plan        String @default("essential")

  // ── Contact & Location ──────────────────────────────────────────────────────
  phone   String?
  address String?
  website String?
  // String[] — e.g. ["Odontología General", "Estética Dental"]
  specialties Json?

  // ── Working hours ───────────────────────────────────────────────────────────
  // Shape: { "lunes": { "open": "09:00", "close": "18:00", "active": true }, ... }
  workingHours Json?

  // ── AI agent identity ───────────────────────────────────────────────────────
  aiAgentName     String?
  // "profesional" | "amigable" | "empático" | "formal"
  aiTone          String?
  aiVoiceId        String?
  vapiAssistantId  String?
  vapiPhoneNumberId String?
  voicePhoneNumber  String?

  // ── AI knowledge base — drives customizationPrompt synthesis ────────────────
  // { question: string; answer: string }[]
  faqs               Json?
  // String[] — e.g. ["Efectivo", "Tarjeta de crédito", "Transferencia"]
  paymentMethods     Json?
  // String[] — e.g. ["GNP", "IMSS", "AXA"]
  insurancesAccepted Json?
  cancellationPolicy String?
  hasParking         Boolean @default(false)
  hasInvoicing       Boolean @default(false)

  // ── AI system prompt — stored encrypted (lib/encryption.ts) ─────────────────
  customizationPrompt String?

  // ── External integrations ───────────────────────────────────────────────────
  // Encrypted JSON: { "zoho": "key", "hubspot": "key" }
  crmApiKeys    String?
  webhookSecret String?

  // ── WhatsApp (Twilio) ────────────────────────────────────────────────────────
  // E.164 format, e.g. "+521234567890" — the Twilio number assigned to this clinic
  whatsappPhone String? @unique

  // ── Meta (Facebook Messenger + Instagram DMs) ────────────────────────────────
  // Facebook Page ID and long-lived Page Access Token (encrypted)
  facebookPageId    String? @unique
  facebookPageToken String? // encrypted with lib/encryption.ts
  // Instagram Business Account ID (linked to the Facebook Page)
  instagramAccountId String? @unique

  // ── Google Calendar ──────────────────────────────────────────────────────────
  // Encrypted OAuth2 refresh token — set via /api/calendar/callback
  googleRefreshToken String?

  // ── Onboarding state ────────────────────────────────────────────────────────
  onboardingCompleted Boolean @default(false)

  services              Service[]
  leads                 Lead[]
  branches              Branch[]
  whatsappConversations WhatsAppConversation[]
  metaConversations     MetaConversation[]
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  @@index([clerkUserId])
}

// ─── Service ──────────────────────────────────────────────────────────────────
// Replaced atomically on each onboarding save (deleteMany + createMany in tx).
// priceMin/priceMax drives the Revenue Asegurado calculation in BI.

model Service {
  id           String  @id @default(cuid())
  clinicId     String
  clinic       Clinic  @relation(fields: [clinicId], references: [id], onDelete: Cascade)

  name         String
  description  String?
  priceMin     Float?
  priceMax     Float?
  durationMins Int?
  active       Boolean @default(true)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([clinicId])
}

// ─── Lead ─────────────────────────────────────────────────────────────────────

model Lead {
  id       String @id @default(cuid())
  clinicId String
  clinic   Clinic @relation(fields: [clinicId], references: [id], onDelete: Cascade)

  // Stored encrypted (lib/encryption.ts)
  patientName  String?
  patientPhone String?

  status  LeadStatus  @default(NUEVO)
  channel LeadChannel @default(LLAMADA)

  appointmentValue Float?

  // Appointment scheduling & reminders
  appointmentAt  DateTime? // UTC — used for 24h reminder cron
  reminderSentAt DateTime? // set when 24h WhatsApp reminder is sent

  // From voice provider webhook
  callId         String?  @unique
  callDurationMs Int?
  callTranscript String?  // encrypted
  callEndedAt    DateTime?

  notes String? // encrypted

  // Google Calendar event ID — set when a calendar event is created for this appointment
  googleCalendarEventId String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([clinicId, status])
  @@index([clinicId, createdAt])
  @@index([callId])
}

// ─── Branch ───────────────────────────────────────────────────────────────────
// A physical location / sucursal belonging to a multi-branch clinic (Business plan).

model Branch {
  id        String @id @default(cuid())
  clinicId  String
  clinic    Clinic @relation(fields: [clinicId], references: [id], onDelete: Cascade)

  name         String
  address      String?
  phone        String?
  whatsappPhone String?
  managerName  String?
  active       Boolean @default(true)

  // Shape: { "lunes": { "open": "09:00", "close": "18:00", "active": true }, ... }
  workingHours Json?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([clinicId])
}

// ─── WhatsApp Conversation ────────────────────────────────────────────────────
// Stores per-patient chat history for stateful WhatsApp conversations.
// Messages older than 24 h are considered a new session (WhatsApp policy).

model WhatsAppConversation {
  id          String   @id @default(cuid())
  clinicId    String
  clinic      Clinic   @relation(fields: [clinicId], references: [id], onDelete: Cascade)
  fromPhone   String   // patient's E.164 phone number
  role        String   // "user" | "assistant"
  content     String
  createdAt   DateTime @default(now())

  @@index([clinicId, fromPhone, createdAt])
}

// ─── Meta Conversation ─────────────────────────────────────────────────────────
// Stores per-sender chat history for Facebook Messenger and Instagram DMs.

model MetaConversation {
  id        String   @id @default(cuid())
  clinicId  String
  clinic    Clinic   @relation(fields: [clinicId], references: [id], onDelete: Cascade)
  senderId  String   // Meta PSID or Instagram IGSID
  channel   String   // "messenger" | "instagram"
  role      String   // "user" | "assistant"
  content   String
  createdAt DateTime @default(now())

  @@index([clinicId, senderId, createdAt])
}
